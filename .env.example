# ============================================================
# PostgreSQL (VPS — install Postgres locally, no Supabase)
# ============================================================

# Example: postgresql://g6audit:STRONG_PASSWORD@127.0.0.1:5432/g6audit
DATABASE_URL=

# Session signing secret — min 32 chars. Generate: openssl rand -hex 32
SESSION_SECRET=

# ============================================================
# Evolution API
# ============================================================

EVOLUTION_API_URL=
EVOLUTION_GLOBAL_KEY=

# ============================================================
# Encryption
# ============================================================

# Encrypts WhatsApp instance API keys at rest (AES-256-GCM)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ============================================================
# OpenAI (used for AI Settings generation on audit reports)
# ============================================================

OPENAI_API_KEY=

# ============================================================
# Feature flags
# ============================================================

META_API_ENABLED=false
STORE_RAW=false

# Audit time budget (ms). On a VPS you can run long jobs — default 10 minutes.
AUDIT_SOFT_DEADLINE_MS=600000

# Mark stuck pending/running audits as failed after this many ms (default 35 min).
AUDIT_STALE_TIMEOUT_MS=2100000
