# ============================================================
# Evolution API
# ============================================================

# Base URL of your self-hosted Evolution API v2 instance
# Example: https://evolution.yourdomain.com
EVOLUTION_API_URL=

# Global admin API key (used ONLY to list/manage instances)
# Find this in your Evolution API server config
EVOLUTION_GLOBAL_KEY=

# ============================================================
# Supabase
# ============================================================

# Your Supabase project URL (safe to expose — public)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose — public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase service role key — NEVER expose this client-side
# Used only in server actions and route handlers
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Encryption
# ============================================================

# Key used to encrypt WhatsApp instance API keys at rest (AES-256-GCM)
# Must be at least 16 characters. Generate with: openssl rand -hex 32
# NEVER expose this key — store it only in Vercel env vars
ENCRYPTION_KEY=

# ============================================================
# Feature Flags
# ============================================================

# Set to 'true' to enable Meta Graph API integration (optional)
# When false, Meta ad data comes from CSV/XLSX uploads only
META_API_ENABLED=false

# Set to 'true' to store raw message body text in the database
# Default: false (PDPA-safe — only metadata and metrics are persisted)
STORE_RAW=false

# Audit time budget before saving a partial report (milliseconds).
# Default 45000 is safe for Vercel Hobby (60s function limit).
# Set to 260000 for Vercel Pro (300s limit) to allow full audits on large accounts.
AUDIT_SOFT_DEADLINE_MS=45000
